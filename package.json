{
  "name": "@technomoron/mail-magic",
  "version": "2.0.0-beta1",
  "private": true,
  "packageManager": "pnpm@10.28.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "sync:shared": "node ./scripts/sync-shared-code.cjs",
    "build": "run-s build:server build:client build:cli build:admin",
    "client": "run-s build:client",
    "cli": "run-s build:cli",
    "server": "run-s build:server",
    "admin": "run-s build:admin",
    "build:client": "pnpm --filter ./packages/client run build",
    "build:cli": "pnpm --filter ./packages/cli run build",
    "build:server": "pnpm --filter ./packages/server run build",
    "build:admin": "pnpm --filter ./packages/admin run build",
    "examples": "node packages/server/dist/esm/bin/mail-magic.js --env packages/server/examples/.env-dist --config packages/server/examples/data",
    "test:client": "run-s --silent test:client:pkg",
    "test:client:pkg": "pnpm --silent --filter ./packages/client run test",
    "test:cli": "run-s --silent test:cli:pkg",
    "test:cli:pkg": "pnpm --silent --filter ./packages/cli run test",
    "test:server": "run-s --silent test:server:pkg",
    "test:server:pkg": "pnpm --silent --filter ./packages/server run test",
    "test:examples": "pnpm --silent --filter ./packages/cli exec vitest run --silent --reporter=dot tests/cli-helpers.test.ts -t \"compiles the examples data directory\"",
    "test:function": "vitest run --silent --reporter=dot",
    "test": "run-s --silent test:server test:client test:cli test:examples test:function",
    "lint:eslint": "eslint --no-error-on-unmatched-pattern ./",
    "lint:stylelint": "stylelint --allow-empty-input \"**/*.{css,scss}\"",
    "lint": "eslint --no-error-on-unmatched-pattern ./ && stylelint --allow-empty-input \"**/*.{css,scss}\"",
    "format": "run-s lintfix pretty",
    "release:check": "bash ./scripts/release-check.sh",
    "release:preflight": "bash ./scripts/release-preflight.sh",
    "release:publish:dry-run": "bash ./scripts/release-package-publish.sh --dry-run",
    "release:verify": "bash ./scripts/release-verify.sh",
    "release": "bash ./scripts/release.sh",
    "lintfix:eslint": "eslint --fix --no-error-on-unmatched-pattern ./",
    "lintfix:stylelint": "stylelint --allow-empty-input --fix \"**/*.{css,scss}\"",
    "lintfix": "eslint --fix --no-error-on-unmatched-pattern ./ && stylelint --allow-empty-input --fix \"**/*.{css,scss}\"",
    "pretty": "prettier --write \"**/*.{js,jsx,cjs,mjs,ts,tsx,mts,vue,json,css,scss,md}\"",
    "clean:dist": "rimraf ./dist/",
    "cleanbuild": "rimraf dist && run-s format build",
    "lintconfig": "node lintconfig.cjs --auto --vue"
  },
  "license": "MIT",
  "copyright": "Copyright (c) 2025 Bj\u00f8rn Erik Jacobsen",
  "devDependencies": {
    "@eslint/markdown": "^7.5.1",
    "@types/node": "^20.19.11",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-vue": "^10.8.0",
    "jsonc-eslint-parser": "^2.4.2",
    "mailparser": "^3.9.1",
    "npm-run-all": "^4.1.5",
    "pnpm": "^10.28.1",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "smtp-server": "^3.18.0",
    "stylelint": "^17.3.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "supertest": "^7.1.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "vue-eslint-parser": "^10.4.0"
  }
}
