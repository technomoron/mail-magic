NODE_ENV=development
API_PORT=3776
API_HOST=127.0.0.1
API_URL=http://127.0.0.1:3776/api
API_BASE_PATH=/api
ASSET_ROUTE=/asset
CONFIG_PATH=./data
DB_TYPE=sqlite
DB_NAME=./maildata.db
DB_FORCE_SYNC=true
DB_AUTO_RELOAD=false
DB_SYNC_ALTER=false
DB_LOG=false
DEBUG=false
AUTOESCAPE_HTML=true
UPLOAD_PATH=./{domain}/uploads
SMTP_HOST=127.0.0.1
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_TLS_REJECT=false
API_TOKEN_PEPPER=example-token-pepper-value
