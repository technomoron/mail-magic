{
	"name": "@technomoron/mail-magic-cli",
	"version": "2.0.0-beta1",
	"description": "CLI for mail-magic",
	"main": "dist/cli.js",
	"bin": {
		"mm-cli": "dist/cli.js",
		"mail-magic-cli": "dist/cli.js"
	},
	"scripts": {
		"prepare": "run-s build",
		"scrub": "rimraf node_modules pnpm-lock.yaml package-lock.json yarn.lock dist/",
		"sync:shared": "node ../../scripts/sync-shared-code.cjs >/dev/null",
		"build:ts": "tsc --project tsconfig/tsconfig.json",
		"build": "run-s sync:shared build:ts",
		"test:unit": "vitest run --no-cache --silent --reporter=dot",
		"test": "run-s --silent sync:shared test:unit",
		"test:watch": "vitest",
		"lint": "node ../../node_modules/eslint/bin/eslint.js --config ../../eslint.config.mjs --no-error-on-unmatched-pattern --ext .js,.cjs,.mjs,.ts,.mts,.tsx,.vue,.json ./src ./tests",
		"lintfix": "node ../../node_modules/eslint/bin/eslint.js --config ../../eslint.config.mjs --fix --no-error-on-unmatched-pattern --ext .js,.cjs,.mjs,.ts,.mts,.tsx,.vue,.json ./src ./tests",
		"pretty": "node ../../node_modules/prettier/bin/prettier.cjs --config ../../.prettierrc --write \"**/*.{js,ts,vue,json,css,scss,md}\"",
		"format": "run-s lintfix pretty",
		"cleanbuild": "run-s clean:dist format build",
		"clean:dist": "rimraf ./dist/",
		"release": "bash ../../scripts/release-package.sh .",
		"release:check": "bash ../../scripts/release-package-check.sh .",
		"release:preflight": "bash ../../scripts/release-package-preflight.sh ."
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/technomoron/mail-magic.git",
		"directory": "packages/cli"
	},
	"author": "Bjørn Erik Jacobsen",
	"license": "MIT",
	"copyright": "Copyright (c) 2026 Bjørn Erik Jacobsen / Technomoron.com",
	"files": [
		"dist/**/*.js",
		"README.md",
		"CHANGES",
		"package.json"
	],
	"dependencies": {
		"@technomoron/mail-magic-client": "^2.0.0-beta1",
		"cheerio": "^1.1.2",
		"commander": "^10.0.1",
		"juice": "^11.0.1",
		"nunjucks": "^3.2.4"
	},
	"devDependencies": {
		"@types/node": "^20.19.11",
		"@types/nunjucks": "^3.2.6",
		"typescript": "^5.9.3",
		"vitest": "^4.0.16"
	},
	"bugs": {
		"url": "https://github.com/technomoron/mail-magic/issues"
	},
	"homepage": "https://github.com/technomoron/mail-magic#readme"
}
